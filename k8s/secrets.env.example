# Copy this file to secrets.env and replace all values.
# Do not commit k8s/secrets.env.

# Shared secret configured in GitLab webhook settings
WEBHOOK_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# GitLab Personal/Project Access Token (scopes: api, read_repository, write_repository)
GITLAB_TOKEN=REPLACE_WITH_GITLAB_TOKEN

# API key for the crush model provider endpoint (any non-empty string if auth disabled)
CRUSH_API_KEY=REPLACE_WITH_CRUSH_API_KEY
