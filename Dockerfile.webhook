# Dockerfile.webhook – build the GitLab webhook receiver
FROM python:3.11-slim

WORKDIR /app

# Install dependencies
COPY webhook_receiver/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy application
COPY webhook_receiver/ /app/webhook_receiver/

# Non-root user
RUN useradd -m -u 1000 appuser
USER appuser

EXPOSE 8080

CMD ["uvicorn", "webhook_receiver.main:app", "--host", "0.0.0.0", "--port", "8080"]
